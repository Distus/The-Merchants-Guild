<div class="merchants-guild-manager">
  <div class="mg-header">
    <h2><i class="fas fa-store"></i> Shop Manager</h2>
    <button class="create-shop-btn" type="button">
      <i class="fas fa-plus"></i> Create New Shop
    </button>
  </div>

  {{#if hasLocations}}
    <div class="mg-filter-bar">
      <label><i class="fas fa-map-marker-alt"></i> Location:</label>
      <select class="mg-location-filter">
        <option value="all" {{#if (eq locationFilter "all")}}selected{{/if}}>All Locations ({{totalShopCount}})</option>
        {{#each locations}}
          <option value="{{this}}" {{#if (eq this ../locationFilter)}}selected{{/if}}>{{this}}</option>
        {{/each}}
        <option value="unassigned" {{#if (eq locationFilter "unassigned")}}selected{{/if}}>Unassigned</option>
      </select>
    </div>
  {{/if}}

  {{#if hasShops}}
    <div class="mg-shop-list">
      {{#each shops}}
        <div class="mg-shop-entry" data-shop-id="{{this.id}}" data-shop-name="{{this.name}}">
          <div class="mg-shop-info">
            <div class="mg-shop-name">{{this.name}}</div>
            <div class="mg-shop-meta">
              <span class="mg-type-badge">{{this.typeLabel}}</span>
              <span class="mg-affluence-badge mg-affluence-{{this.affluenceTier}}">{{this.affluenceLabel}}</span>
              {{#if this.location}}
                <span class="mg-location-badge"><i class="fas fa-map-marker-alt"></i> {{this.location}}</span>
              {{/if}}
            </div>
            <div class="mg-shop-keeper">
              <i class="fas fa-user"></i> {{this.shopkeeperName}}
            </div>
          </div>
          <div class="mg-shop-actions">
            <button class="shop-open-btn" type="button" title="Open Shop">
              <i class="fas fa-door-open"></i>
            </button>
            <button class="shop-delete-btn" type="button" title="Delete Shop">
              <i class="fas fa-trash"></i>
            </button>
          </div>
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="mg-empty-state">
      <i class="fas fa-store-slash"></i>
      <p>No shops yet. Click "Create New Shop" to get started.</p>
    </div>
  {{/if}}
</div>
